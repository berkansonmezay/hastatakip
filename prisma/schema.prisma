// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  DOCTOR
  SECRETARY
  ACCOUNTING
  LAB
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String
  role          Role      @default(SECRETARY)
  appointments  Appointment[] @relation("DoctorAppointments")
  examinations  Examination[] @relation("DoctorExaminations")
  labTests      LabTest[]     @relation("DoctorLabTests")
  prescriptions Prescription[] @relation("DoctorPrescriptions")
  notifications Notification[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Patient {
  id            String    @id @default(cuid())
  fullName      String
  tcNo          String?   @unique
  phone         String?
  email         String?
  address       String?
  gender        String?
  birthDate     DateTime?
  bloodGroup    String?
  insuranceInfo String?
  notes         String?
  appointments  Appointment[]
  examinations  Examination[]
  payments      Payment[]
  labTests      LabTest[]
  prescriptions Prescription[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Appointment {
  id            String    @id @default(cuid())
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        User      @relation("DoctorAppointments", fields: [doctorId], references: [id])
  dateTime      DateTime
  status        String    @default("PENDING") // PENDING, COMPLETED, CANCELLED
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Examination {
  id            String    @id @default(cuid())
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        User      @relation("DoctorExaminations", fields: [doctorId], references: [id])
  complaint     String?
  diagnosis     String?
  treatment     String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Payment {
  id            String    @id @default(cuid())
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id])
  amount        Float
  type          String    // CASH, CREDIT_CARD, TRANSFER
  date          DateTime  @default(now())
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Treatment {
  id          String   @id @default(cuid())
  name        String
  category    String?
  cost        Float    @default(0)
  duration    Int?     // Duration in minutes
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InventoryItem {
  id           String    @id @default(cuid())
  name         String
  category     String
  quantity     Int       @default(0)
  unit         String    // e.g. Box, Bottle, Piece
  unitPrice    Float     @default(0)
  minThreshold Int       @default(10)
  expiration   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model LabTest {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id])
  doctorId  String
  doctor    User     @relation("DoctorLabTests", fields: [doctorId], references: [id])
  testName  String
  result    String?
  status    String   @default("PENDING") // PENDING, COMPLETED
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Prescription {
  id        String             @id @default(cuid())
  patientId String
  patient   Patient            @relation(fields: [patientId], references: [id])
  doctorId  String
  doctor    User               @relation("DoctorPrescriptions", fields: [doctorId], references: [id])
  diagnosis String?
  notes     String?
  date      DateTime           @default(now())
  items     PrescriptionItem[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model PrescriptionItem {
  id             String       @id @default(cuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicineName   String
  dosage         String
  frequency      String
  duration       String
}
